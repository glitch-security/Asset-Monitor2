# =============================================================================
# AssetMonitor — .gitignore
# =============================================================================

# ----- Database files -----
data/
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# ----- Python bytecode -----
*.pyc
*.pyo
*.pyd
__pycache__/
*.egg-info/
dist/
build/
.eggs/

# ----- Virtual environments -----
.venv/
venv/
env/
ENV/
.env.*/

# ----- Environment / secrets -----
.env
.env.*
*.env
secrets.yaml
secrets.yml
secrets.json
credentials.json
*.key
*.pem
*.p12
*.pfx

# ----- User-specific config & target files -----
# (kept out of version control; copy from *.example to get started)
config.yaml
domains.txt
subdomains.txt
websites.txt

# ----- Generated reports -----
report.json
report.html
reports/

# ----- Screenshots -----
screenshots/
screenshots/*.png
screenshots/*.jpg

# ----- OS noise -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ----- Editor / IDE -----
.idea/
.idea
.vscode/
.cursor/
.claude/
.aider/
.continue/
.copilot/
*.swp
*.swo
*~
*.orig
*.bak
.project
.classpath
.settings/
*.iml
*.sublime-workspace
*.sublime-project

# ----- AI / Agent tools -----
.claude/
.cursor/
.aider/
.aider.tags.cache.v3/
.aider.chat.history.md
.continue/
.copilot/
copilot-instructions.md
*.ai-notes.md
ai-context/
llm-context/
agent-scratchpad/
CLAUDE.md
CODEBASE.md
instructions.md
*_MEMORY.md
*_INTERNAL.md
*_INSTRUCTIONS.md

# ----- Pytest / coverage -----
.pytest_cache/
.coverage
coverage.xml
htmlcov/
tests/results.md

# ----- mypy / pyright -----
.mypy_cache/
.pyright/
.pytest_cache/

# ----- Logs -----
*.log
logs/
*.log.*

# ----- Temporary files -----
*.tmp
*.temp
tmp/
temp/

# ----- Build artifacts -----
*.so
*.dylib
*.dll
